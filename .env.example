# Slack credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=  

# Anthropic
ANTHROPIC_API_KEY=
# Brand context for Supabase team
BRAND_NAME=Supabase
BRAND_NICHE=developer tools and infrastructure
BRAND_TONE=professional and technical

# "socket" for local dev, "http" for Railway production
SLACK_MODE=socket

# Set automatically by Railway — do not override in production
PORT=3000

# SocialMediaManager integration — provides brand context + top post benchmarks
# Leave unset to fall back to BRAND_NAME/NICHE/TONE env vars above
SOCIAL_MANAGER_URL=https://social-media-manager-gold-tau.vercel.app
SOCIAL_MANAGER_API_SECRET=
