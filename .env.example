# Slack credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=  

# Anthropic
ANTHROPIC_API_KEY=
# Brand context for Supabase team
BRAND_NAME=Supabase
BRAND_NICHE=developer tools and infrastructure
